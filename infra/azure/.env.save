# Copie pra .env (que vai no gitignore) e preencha.
# Source carregado pelos scripts: `source .env`

# ===== Azure =====
AZURE_SUBSCRIPTION_ID=25a5253f-c671-40df-9fc5-2b7fca9d9bda
AZURE_LOCATION=eastus
AZURE_RESOURCE_GROUP=gy-teste

# Sufixo curto (5-6 chars) pra garantir nomes globalmente unicos em ACR,
# storage, postgres etc. Use algo como suas iniciais + numero aleatorio.
AZURE_SUFFIX=gy1234

# ===== Postgres admin =====
# NAO use caracteres especiais de shell como $ ` " ' \ aqui.
PG_ADMIN_USER=gy_admin
PG_ADMIN_PASSWORD=TrocaEstaSenha2026!Forte

# ===== CloudAMQP (cole apos criar a conta) =====
# Formato: amqps://<user>:<pass>@<host>/<vhost>
CLOUDAMQP_URL=

# ===== Preenchido automaticamente apos provision.sh =====
# Nao mexe nos valores abaixo manualmente; deixa o script atualizar.
AZURE_ACR_NAME=AZURE_SUFFIX=caio01
AZURE_STORAGE_ACCOUNT=PG_ADMIN_PASSWORD=GreenYellow2026Forte!
AZURE_STORAGE_CONTAINER=csv-uploadsxx
AZURE_PG_SERVER=
AZURE_PG_DATABASE=gy_metrics
AZURE_CAE_NAME=
AZURE_BACKEND_APP=gy-api
AZURE_FRONTEND_APP=gy-frontend
